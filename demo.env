# Port to run the server on
PORT=4000

# MongoDB URI (defaulting to local or replacement placeholder)
MONGODB_URI=mongodb://localhost:27017/chatappwithai

# JWT secret key for signing tokens
JWT_SECRET=your_jwt_secret

# Google Gemini AI API key
GOOGLE_AI_KEY=your_gemini_api_key

# --- REDIS CONFIGURATION ---
# Note: You can use Option A (REDIS_URI) OR Option B (separate host, port, password values).

# Option A: Single Connection URI
REDIS_URI=redis://:your_redis_password@your_redis_host:your_redis_port

# Option B: Individual connection credentials
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
